<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Deep Slate Base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F172A" />
        </shape>
    </item>

    <!-- 2. Indigo Glow (Top Center) -->
    <item android:top="-200dp">
        <shape android:shape="oval">
            <size android:width="800dp" android:height="800dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.5"
                android:centerY="0.2"
                android:startColor="#102563EB"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- 3. Amber Accent (Bottom Left) -->
    <item android:bottom="-150dp" android:left="-150dp">
        <shape android:shape="oval">
            <size android:width="600dp" android:height="600dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:startColor="#08F59E0B"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>