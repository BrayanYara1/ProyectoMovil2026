<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Borde de brillo exterior -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#2042A17B" />
        </shape>
    </item>

    <!-- 2. Relleno con Gradiente Vibrante -->
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#F0F7F4"
                android:startColor="#FFFFFF"
                android:type="linear" />
            <stroke
                android:width="1.5dp"
                android:color="#4042A17B" />
        </shape>
    </item>

    <!-- 3. Brillo interno superior -->
    <item android:bottom="12dp" android:left="8dp" android:right="12dp" android:top="6dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#A0FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>