<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.App.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dateIconCard"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:transitionName="date_container_shared"
            app:cardBackgroundColor="@color/primary_container"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvItemDiaMes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="15" />

                <TextView
                    android:id="@+id/tvItemMesCorta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="OCT" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvItemNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:transitionName="patient_name"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvItemHora"
            app:layout_constraintStart_toEndOf="@id/dateIconCard"
            app:layout_constraintTop_toTopOf="@id/dateIconCard"
            tools:text="Dr. Juan Pérez" />

        <TextView
            android:id="@+id/tvItemMotivo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="@id/tvItemNombre"
            app:layout_constraintStart_toStartOf="@id/tvItemNombre"
            app:layout_constraintTop_toBottomOf="@id/tvItemNombre"
            tools:text="Consulta General - Chequeo anual" />

        <TextView
            android:id="@+id/tvItemHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvItemNombre"
            tools:text="09:30 AM" />

        <com.google.android.material.chip.Chip
            android:id="@+id/tvItemStatus"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/white"
            android:textSize="10sp"
            app:chipBackgroundColor="@color/status_pending_bg"
            app:chipCornerRadius="4dp"
            app:chipStrokeWidth="0dp"
            app:layout_constraintStart_toStartOf="@id/tvItemNombre"
            app:layout_constraintTop_toBottomOf="@id/tvItemMotivo"
            tools:text="PENDIENTE" />

        <ImageButton
            android:id="@+id/btnDeleteItem"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_delete"
            android:padding="4dp"
            android:src="@drawable/ic_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/error" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
